generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  telegramId   String         @id
  username     String?
  profileName  String?
  referralCode String         @unique
  referredBy   String?
  subscriptions Subscription[]
  payments      Payment[]
}

model Payment {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [telegramId])
  userId      String
  gatewayTxId String   @unique
  amount      Float
  status      String   
  qrCode      String?
  planDays    Int      @default(30)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model Subscription {
  id          String   @id @default(uuid())
  userId      String
  status      String   
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [telegramId])
}

model Config {
  id                 String  @id @default("default")
  welcomeText        String  @default("Bem-vindo ao nosso Bot VIP. Escolha uma opção no menu abaixo:")
  welcomeMediaId     String? 
  welcomeMediaType   String? 
  logGroupId         String?
  monthlyPrice       Float   @default(30.00)
  monthlyActive      Boolean @default(true)
  quarterlyPrice     Float   @default(80.00)
  quarterlyActive    Boolean @default(false)
  lifetimePrice      Float   @default(200.00)
  lifetimeActive     Boolean @default(false)
}
